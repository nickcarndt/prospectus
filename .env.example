# Required for SEC EDGAR downloads (app name + contact email).
# https://www.sec.gov/os/accessing-edgar-data
SEC_USER_AGENT=Prospectus Research you@example.com

# Local Postgres (docker compose in /infra)
DATABASE_URL=postgresql://prospectus:prospectus@localhost:5432/prospectus

# OpenAI — embeddings (Phase 3+)
OPENAI_API_KEY=sk-...

# Cohere — rerank cross-encoder (Phase 5+)
COHERE_API_KEY=...

# Anthropic — cited generation (Phase 6+)
ANTHROPIC_API_KEY=...
# Optional overrides (defaults: claude-sonnet-4-5 / 2048)
# ANTHROPIC_MODEL=claude-sonnet-4-5
# ANTHROPIC_MAX_TOKENS=2048

# Braintrust — eval tracing (Phase 7+); optional for local JSON results
BRAINTRUST_API_KEY=...

# API CORS — comma-separated extra origins (local defaults always included)
# CORS_ORIGINS=https://your-app.vercel.app

# Frontend (apps/web/.env.local) — not used by the API
# NEXT_PUBLIC_API_URL=http://localhost:8000
